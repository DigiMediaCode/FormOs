DATABASE_URL=
# Direct PostgreSQL connection for Prisma CLI/schema operations.
# For Supabase, use the direct connection string on port 5432, not the pooled PgBouncer URL on port 6543.
DIRECT_URL=
AUTH_SECRET=
EMAIL_PROVIDER=lark
LARK_APP_ID=
LARK_APP_SECRET=
LARK_SENDER_EMAIL=
# Optional: Lark Mail send API requires a user access token for the sender mailbox.
# If omitted, FormOS tries the tenant token and logs the Lark API error safely.
LARK_USER_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
NEXT_PUBLIC_APP_URL=
APP_URL=

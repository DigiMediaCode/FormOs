DATABASE_URL=
# Direct PostgreSQL connection for Prisma CLI/schema operations.
# For Supabase, use the direct connection string on port 5432, not the pooled PgBouncer URL on port 6543.
DIRECT_URL=
AUTH_SECRET=
EMAIL_PROVIDER=lark
# Lark Mail is the transactional email provider (verification, OTP, notifications).
# These are NOT for social login — "Login with Lark" has been removed.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_SENDER_EMAIL=
# Lark Mail OAuth callback. Production example:
# https://formos.com.au/api/integrations/lark-mail/callback
LARK_REDIRECT_URI=
# Optional emergency override. Prefer connecting Lark Mail in Settings / Integrations.
LARK_USER_ACCESS_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=
# Social login providers (buttons appear only when a provider's keys are all set).
# Microsoft (Azure AD app registration, "common" multi-tenant).
# Redirect example: https://formos.com.au/api/auth/microsoft/callback
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
MICROSOFT_AUTH_REDIRECT_URI=
# Facebook (Meta app, Facebook Login product).
# Redirect example: https://formos.com.au/api/auth/facebook/callback
FACEBOOK_AUTH_CLIENT_ID=
FACEBOOK_AUTH_CLIENT_SECRET=
FACEBOOK_AUTH_REDIRECT_URI=
# Apple (Sign in with Apple; Services ID + key). Redirect must be HTTPS.
# Redirect example: https://formos.com.au/api/auth/apple/callback
APPLE_AUTH_CLIENT_ID=
APPLE_AUTH_TEAM_ID=
APPLE_AUTH_KEY_ID=
# Contents of the .p8 private key (use \n for newlines if kept on one line).
APPLE_AUTH_PRIVATE_KEY=
APPLE_AUTH_REDIRECT_URI=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_RETURN_URL=
NEXT_PUBLIC_APP_URL=
APP_URL=

# Copy this file to shopify.app.toml only inside a Shopify app project.
# Replace placeholders with values generated by Shopify CLI / Partner Dashboard.

name = "FormOS Embed"
client_id = "REPLACE_WITH_SHOPIFY_CLIENT_ID"
application_url = "https://example.com"
embedded = true

[build]
automatically_update_urls_on_dev = true

[access_scopes]
scopes = ""

[auth]
redirect_urls = [
  "https://example.com/auth/callback"
]

[webhooks]
api_version = "2026-01"

[pos]
embedded = false


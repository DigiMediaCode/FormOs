{
  "include": [
    "env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["node", "vite/client"]
  }
}

